# Local preview secrets for `npx wrangler pages dev .`
# Copy this file to `.dev.vars` (which is git-ignored) and fill in real values.
# In production these are set in the Cloudflare Pages dashboard, NOT from this file.

SITE_PASSWORD="choose-a-shared-password"
GATE_SECRET="paste-any-long-random-string-here-40-plus-characters"

# Optional — PostHog analytics (covers both the cover page and the proposal).
# Leave unset to keep analytics off.
POSTHOG_KEY="phc_your_project_api_key"
POSTHOG_HOST="https://us.i.posthog.com"   # or https://eu.i.posthog.com
